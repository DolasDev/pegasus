{
  "name": "pegasus",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "deploy": "bash packages/infra/deploy.sh",
    "create-admin-user": "tsx scripts/create-admin-user.ts",
    "setup": "bash scripts/setup.sh",
    "prepare": "node ./node_modules/husky/bin.js || true",
    "launch-agent": "bash ./scripts/launch_agent.sh",
    "remove-agent": "bash ./scripts/remove_agent.sh",
    "e2e": "turbo run e2e --filter=@pegasus/e2e"
  },
  "devDependencies": {
    "@aws-sdk/client-ssm": "^3.1037.0",
    "@aws-sdk/credential-providers": "^3.1037.0",
    "@eslint/js": "^10.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "//overrides": {
    "handlebars": "CVE-2019-19919 prototype pollution",
    "flatted": "security fix",
    "@xmldom/xmldom": "CVE-2022-39353 XML parsing (>=0.8.10 has fix; 0.9.x breaks @expo/plist mimeType API)",
    "defu": "prototype pollution fix",
    "undici": "HTTP request smuggling fixes",
    "path-to-regexp": "ReDoS vulnerability",
    "picomatch": "ReDoS vulnerability",
    "rollup": "esbuild CVE transitive fix",
    "yaml": "CVE-2023-2251 code injection",
    "minimatch": "ReDoS vulnerability",
    "ajv": "prototype pollution",
    "eslint.ajv": "ESLint uses ajv v6 internally",
    "effect": "compatibility fix",
    "esbuild": "GHSA-67mh-4wv8-2f99 moderate CVE",
    "react": "Expo SDK 55 pins to 19.2.0. React must be one version tree-wide (singleton peer), so every workspace + transitive gets this version.",
    "react-dom": "Matches react override.",
    "react-native": "Expo SDK 55 expects 0.83.6; transitive bumps via @react-navigation would otherwise pull 0.85.x.",
    "react-test-renderer": "Pinned to match react exactly (the package requires react ^<its own>)."
  },
  "overrides": {
    "handlebars": ">=4.7.9",
    "flatted": ">=3.4.2",
    "@xmldom/xmldom": ">=0.9.9",
    "@expo/plist": {
      "@xmldom/xmldom": "^0.8.10"
    },
    "plist": {
      "@xmldom/xmldom": "^0.8.10"
    },
    "defu": ">=6.1.5",
    "undici": ">=7.24.0 <8.0.0",
    "path-to-regexp": ">=8.4.0",
    "picomatch": ">=4.0.4",
    "rollup": ">=4.58.1",
    "yaml": ">=2.8.3",
    "minimatch": ">=3.1.4",
    "ajv": ">=8.18.0",
    "eslint": {
      "ajv": "^6.14.0",
      "@eslint/eslintrc": {
        "ajv": "^6.14.0"
      }
    },
    "effect": ">=3.20.0",
    "esbuild": ">=0.25.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-test-renderer": "19.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0"
  }
}
