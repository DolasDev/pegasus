{
  "name": "@pegasus/api",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "start:dev": "tsx src/server.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "service:install": "node service/install.js",
    "service:uninstall": "node service/uninstall.js",
    "service:reinstall": "turbo run build --filter=@pegasus/api && npm run service:uninstall && npm run service:install"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.0",
    "@aws-sdk/client-ec2": "^3.1039.0",
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-s3": "^3.1034.0",
    "@aws-sdk/client-ssm": "^3.1039.0",
    "@aws-sdk/s3-request-presigner": "^3.1034.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.3.0",
    "@napi-rs/canvas": "^0.1.99",
    "@noble/curves": "^1.6.0",
    "@pegasus/domain": "*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.7.1",
    "hono": "^4.12.14",
    "jose": "^6.0.0",
    "knex": "^3.1.0",
    "mssql": "^12.3.1",
    "pdfjs-dist": "^5.6.205",
    "sharp": "^0.34.5",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1034.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "prisma": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "*",
    "vitest": "^4.1.5"
  }
}
