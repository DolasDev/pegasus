{
  "name": "@pegasus/api",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "start:dev": "tsx src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "service:install": "node service/install.js",
    "service:uninstall": "node service/uninstall.js"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.32.0",
    "@hono/node-server": "^1.19.12",
    "@hono/zod-openapi": "^0.19.10",
    "@pegasus/domain": "*",
    "@prisma/client": "^6.19.3",
    "fast-xml-parser": "^5.5.10",
    "hono": "^4.12.10",
    "jose": "^5.0.0",
    "knex": "^3.1.0",
    "mssql": "^12.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1025.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/mssql": "^9.1.11",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^3.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "*",
    "vitest": "^3.0.0"
  }
}
