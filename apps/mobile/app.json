{
  "expo": {
    "name": "Moving & Storage Driver",
    "slug": "moving-storage-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "movingapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.movingstorage.driverapp",
      "infoPlist": {
        "NSCameraUsageDescription": "This app requires camera access to capture proof of delivery photos.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select delivery photos.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to optimize delivery routes and track order progress."
      }
    },
    "android": {
      "package": "com.movingstorage.driverapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photos to capture proof of delivery.",
          "cameraPermission": "This app requires camera access to capture proof of delivery photos."
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a2e694fd-15da-47ba-8ef0-8a3e1cd7c4be"
      }
    },
    "owner": "kbeck"
  }
}
