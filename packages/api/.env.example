# ---------------------------------------------------------------------------
# Pegasus API — environment variables
# Copy to .env and fill in your values.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
#
# Option A — Local Docker  (docker compose up -d, then db:migrate + db:seed)
#   Both URLs point to the same local instance — no pooler needed.
#
# Option B — Neon (cloud)
#   DATABASE_URL uses the pooled connection endpoint (for the Lambda runtime).
#   DIRECT_URL  uses the direct connection endpoint (required by Prisma Migrate).
# ---------------------------------------------------------------------------

# Option A — Docker
DATABASE_URL="postgresql://pegasus:pegasus@localhost:5432/pegasus"
DIRECT_URL="postgresql://pegasus:pegasus@localhost:5432/pegasus"

# Option B — Neon (replace with your project's connection strings)
# DATABASE_URL="postgresql://<user>:<password>@<pooler-host>/pegasus?sslmode=require"
# DIRECT_URL="postgresql://<user>:<password>@<direct-host>/pegasus?sslmode=require"

# ---------------------------------------------------------------------------
# AWS Cognito
# ---------------------------------------------------------------------------

# User Pool ID — e.g. us-east-1_AbCdEfGhI
COGNITO_USER_POOL_ID=

# JWKS endpoint used to verify tenant ID tokens.
# Format: https://cognito-idp.<region>.amazonaws.com/<pool-id>/.well-known/jwks.json
COGNITO_JWKS_URL=

# App client ID for the tenant-facing Cognito client
COGNITO_TENANT_CLIENT_ID=

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------------------
# On-Premises / Standalone Server
#
# These settings are used when running the API as a standalone Node.js server
# (npm run start:dev or npm run start) instead of as an AWS Lambda function.
# ---------------------------------------------------------------------------

# HTTP server bind address and port
# PORT=3000
# HOST=0.0.0.0

# Skip Cognito authentication (on-prem / internal network only).
# WARNING: Never enable this in a cloud/production deployment.
# SKIP_AUTH=true

# When SKIP_AUTH=true, use this tenant ID for all requests.
# DEFAULT_TENANT_ID=your-tenant-uuid-here
