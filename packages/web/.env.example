# ---------------------------------------------------------------------------
# Pegasus Web — Vite environment variables
# Copy this file to .env.local and fill in the values from your AWS console
# or CDK stack outputs.
# ---------------------------------------------------------------------------

# API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Cognito — Tenant SSO (Phase 2+)
# Values come from the CognitoStack CDK outputs.
# ---------------------------------------------------------------------------

# AWS region where the User Pool lives (e.g. us-east-1)
VITE_COGNITO_REGION=us-east-1

# User Pool ID (from CDK output: PegasusCognitoUserPoolId)
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx

# Tenant app client ID — no secret, PKCE only
# (from CDK output: PegasusCognitoTenantClientId)
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Hosted UI base URL (from CDK output: PegasusCognitoHostedUiBaseUrl)
# Format: https://pegasus-<accountId>.auth.<region>.amazoncognito.com
VITE_COGNITO_DOMAIN=https://pegasus-123456789.auth.us-east-1.amazoncognito.com

# OAuth callback URL registered in the tenant app client.
# Must exactly match one of the callbackUrls in the CDK CognitoStack.
# For local dev:   http://localhost:5173/login/callback
# For production:  https://<cloudfront-domain>/login/callback
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/login/callback
