# ---------------------------------------------------------------------------
# Pegasus Web — Vite environment variables
#
# NOTE: As of the runtime config migration, VITE_COGNITO_* and VITE_API_URL
# are no longer read by the application at runtime. Configuration is now
# served from /config.json at boot (see packages/web/public/config.json.example).
#
# These vars are kept here for reference only. Copy
# public/config.json.example → public/config.json for local development.
# ---------------------------------------------------------------------------

# API base URL (no longer used at runtime — see public/config.json)
# VITE_API_URL=http://localhost:3000

# Cognito — no longer used at runtime (see public/config.json)
# VITE_COGNITO_REGION=us-east-1
# VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COGNITO_DOMAIN=https://pegasus-123456789.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_REDIRECT_URI=http://localhost:5173/login/callback
