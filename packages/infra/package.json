{
  "name": "@pegasus/infra",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint 'bin/**/*.ts' 'lib/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all",
    "deploy:ci": "cdk deploy ${TARGET:---all} --require-approval never --outputs-file /tmp/pegasus-cdk-outputs.json --app \"npx tsx bin/app.ts\""
  },
  "dependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "aws-cdk": "^2.160.0",
    "typescript": "*",
    "vitest": "^4.0.0"
  }
}
