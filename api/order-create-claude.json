{
    "swagger": "2.0",
    "info": {
        "title": "Comprehensive EDI 204 Motor Carrier Shipment Information API",
        "version": "1.0.0"
    },
    "host": "${ApiGatewayHost}",
    "basePath": "/v1",
    "schemes": ["https"],
    "paths": {
        "/orders/create": {
            "post": {
                "consumes": ["application/json"],
                "produces": ["application/json"],
                "parameters": [{
                    "in": "body",
                    "name": "shipmentRequest",
                    "required": true,
                    "schema": {"$ref": "#/definitions/ShipmentRequest"}
                }],
                "responses": {
                    "200": {
                        "description": "Successful shipment creation",
                        "schema": {"$ref": "#/definitions/ShipmentResponse"}
                    },
                    "400": {"description": "Bad Request - Validation Failed"}
                }
            }
        }
    },
    "definitions": {
        "ShipmentRequest": {
            "type": "object",
            "required": [
                "shipmentIdentification", 
                "shipper", 
                "consignee", 
                "carrier",
                "shipmentDetails"
            ],
            "properties": {
                "shipmentIdentification": {
                    "type": "object",
                    "properties": {
                        "standardCarrierAlphaCode": {"type": "string"},
                        "shipmentReferenceNumbers": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": [
                                            "BILL_OF_LADING", 
                                            "PURCHASE_ORDER", 
                                            "MASTER_BILL", 
                                            "CUSTOMER_REFERENCE",
                                            "TRANSPORTATION_CONTROL_NUMBER"
                                        ]
                                    },
                                    "number": {"type": "string"}
                                }
                            }
                        }
                    }
                },
                "routing": {
                    "type": "object",
                    "properties": {
                        "originLocation": {"$ref": "#/definitions/Location"},
                        "destinationLocation": {"$ref": "#/definitions/Location"},
                        "intermediateStops": {
                            "type": "array",
                            "items": {"$ref": "#/definitions/Location"}
                        },
                        "routingInstructions": {"type": "string"}
                    }
                },
                "shipper": {"$ref": "#/definitions/PartyDetails"},
                "consignee": {"$ref": "#/definitions/PartyDetails"},
                "billTo": {"$ref": "#/definitions/PartyDetails"},
                "carrier": {
                    "type": "object",
                    "properties": {
                        "name": {"type": "string"},
                        "carrierCode": {"type": "string"},
                        "scac": {"type": "string"}
                    }
                },
                "shipmentDetails": {
                    "type": "object",
                    "properties": {
                        "totalWeight": {"type": "number"},
                        "weightUnit": {"type": "string", "enum": ["LBS", "KG"]},
                        "commodityDetails": {
                            "type": "object",
                            "properties": {
                                "description": {"type": "string"},
                                "hazardousMaterials": {
                                    "type": "object",
                                    "properties": {
                                        "unCode": {"type": "string"},
                                        "properShippingName": {"type": "string"},
                                        "hazardClass": {"type": "string"},
                                        "packingGroup": {"type": "string"}
                                    }
                                },
                                "commodityCode": {"type": "string"},
                                "nmfc": {"type": "string"}
                            }
                        },
                        "equipment": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string", 
                                        "enum": [
                                            "VAN", "FLATBED", "REFRIGERATED", 
                                            "TANKER", "CONTAINER", "SPECIALIZED"
                                        ]
                                    },
                                    "size": {"type": "string"},
                                    "specialEquipmentInstructions": {"type": "string"}
                                }
                            }
                        },
                        "specialServices": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "LIFTGATE", "INSIDE_DELIVERY", "RESIDENTIAL", 
                                    "HAZMAT", "REFRIGERATED", "EXPEDITED",
                                    "SORT_AND_SEGREGATE", "PROTECTIVE_SERVICE"
                                ]
                            }
                        },
                        "pickupInstructions": {"type": "string"},
                        "deliveryInstructions": {"type": "string"},
                        "temperatureControl": {
                            "type": "object",
                            "properties": {
                                "required": {"type": "boolean"},
                                "temperature": {"type": "number"},
                                "temperatureUnit": {"type": "string", "enum": ["F", "C"]}
                            }
                        },
                        "scheduling": {
                            "type": "object",
                            "properties": {
                                "requestedPickupDate": {"type": "string", "format": "date-time"},
                                "requestedDeliveryDate": {"type": "string", "format": "date-time"},
                                "earliestPickupDate": {"type": "string", "format": "date-time"},
                                "latestDeliveryDate": {"type": "string", "format": "date-time"}
                            }
                        }
                    }
                },
                "freightCharges": {
                    "type": "object",
                    "properties": {
                        "paymentTerms": {
                            "type": "string", 
                            "enum": [
                                "PREPAID", "COLLECT", "THIRD_PARTY", 
                                "COD", "FREE_DOMICILE"
                            ]
                        },
                        "billOfLadingTerms": {"type": "string"},
                        "freightRateType": {
                            "type": "string", 
                            "enum": [
                                "FLAT_RATE", "WEIGHT_BASED", 
                                "VOLUME_BASED", "SPECIAL_RATE"
                            ]
                        },
                        "totalFreightCharge": {"type": "number"},
                        "currency": {"type": "string", "default": "USD"}
                    }
                }
            }
        },
        "Location": {
            "type": "object",
            "properties": {
                "name": {"type": "string"},
                "address": {
                    "type": "object",
                    "properties": {
                        "streetAddress": {"type": "string"},
                        "city": {"type": "string"},
                        "state": {"type": "string"},
                        "zipCode": {"type": "string"},
                        "country": {"type": "string"}
                    }
                },
                "contactDetails": {
                    "type": "object",
                    "properties": {
                        "contactName": {"type": "string"},
                        "phoneNumber": {"type": "string"}
                    }
                },
                "locationType": {
                    "type": "string", 
                    "enum": [
                        "PICKUP", "DELIVERY", "INTERMEDIATE_STOP", 
                        "WAREHOUSE", "DISTRIBUTION_CENTER"
                    ]
                }
            }
        },
        "PartyDetails": {
            "type": "object",
            "properties": {
                "name": {"type": "string"},
                "address": {
                    "type": "object",
                    "properties": {
                        "streetAddress": {"type": "string"},
                        "city": {"type": "string"},
                        "state": {"type": "string"},
                        "zipCode": {"type": "string"},
                        "country": {"type": "string"}
                    }
                },
                "contactName": {"type": "string"},
                "phoneNumber": {"type": "string"},
                "taxId": {"type": "string"},
                "duns": {"type": "string"}
            }
        },
        "ShipmentResponse": {
            "type": "object",
            "properties": {
                "shipmentId": {"type": "string"},
                "trackingNumber": {"type": "string"},
                "status": {
                    "type": "string",
                    "enum": [
                        "CREATED", "PENDING", "PICKUP_SCHEDULED", 
                        "IN_TRANSIT", "DELIVERED", "EXCEPTION"
                    ]
                },
                "estimatedPickupTime": {"type": "string", "format": "date-time"},
                "estimatedDeliveryTime": {"type": "string", "format": "date-time"},
                "actualPickupTime": {"type": "string", "format": "date-time"},
                "actualDeliveryTime": {"type": "string", "format": "date-time"}
            }
        }
    }
}